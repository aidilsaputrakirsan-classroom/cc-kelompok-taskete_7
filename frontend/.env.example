# Salin ke .env untuk override lokal (file .env tidak di-commit)

# Development (npm run dev) — pakai .env.development (sudah di repo):
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8000

# Production (npm run build) — pakai .env.production (sudah di repo):
VITE_API_URL=https://cc-kelompok-taskete7.akhzafachrozy.my.id/api

# GitHub Actions CD juga bisa override lewat repo Variable: VITE_API_URL
# --- contoh override lokal (langsung ke backend tanpa proxy) ---
VITE_API_URL=http://localhost:8000
VITE_API_PROXY_TARGET=http://localhost:8000
