# Portal Cuti — Environment Variables
# Salin file ini menjadi .env dan sesuaikan nilainya

# ========================
# Database PostgreSQL
# ========================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
# Saat Docker Compose: host = nama service database (db)
DATABASE_URL=postgresql://postgres:postgres@db:5432/simcuti

# ========================
# JWT Authentication
# ========================
SECRET_KEY=portal-cuti-super-secret-key-minimum-32-chars-2025
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ========================
# Server
# ========================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ========================
# CORS — origins yang diizinkan
# ========================
# Pisahkan dengan koma jika lebih dari satu
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
