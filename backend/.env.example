# Database Configuration
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://postgres:YOURPASSWORD@localhost:5432/simcuti

# Server Configuration (opsional, default values digunakan jika tidak diset)
APP_HOST=0.0.0.0
APP_PORT=8000

# Environment: development / production
APP_ENV=development

# JWT
SECRET_KEY=your-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# DeployCC / reverse proxy (kosongkan untuk lokal; production: /api)
# ROOT_PATH=/api