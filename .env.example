# ============================================
# Cloud App — Environment Variables
# ============================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke repository!

# ---- GENERAL ----
ENVIRONMENT=development          # development | production

# ---- AUTH SERVICE ----
AUTH_DB_URL=postgresql://postgres:CHANGE_ME_PASSWORD@auth-db:5432/auth_db
SECRET_KEY=CHANGE_ME_USE_RANDOM_STRING_MIN_32_CHARS_LIKE_abcdef1234567890abcdef1234567890
TOKEN_EXPIRE_MINUTES=30

# ---- ITEM SERVICE ----
ITEM_DB_URL=postgresql://postgres:CHANGE_ME_PASSWORD@item-db:5432/item_db
AUTH_SERVICE_URL=http://auth-service:8001

# ---- DATABASE ----
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD

# ---- FRONTEND ----
VITE_API_URL=http://localhost

# ---- GATEWAY (NGINX) ----
GATEWAY_PORT=80

# ---- LOGGING ----
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ---- TESTING ----
TESTING=false                    # Set to 'true' untuk mode testing
